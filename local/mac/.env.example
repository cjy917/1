# Mac 本地环境变量 — 复制为 .env 后使用（.env 已被 gitignore）
# cp local/mac/.env.example local/mac/.env
#
# 当前团队方案：关闭 AirPlay，全员使用 5000（与 Windows 相同，通常无需本文件）
# 仅当 AirPlay 开启、5000 被占用时，改为 BACKEND_PORT=5001 并配合 local/mac/vite.config.js

BACKEND_PORT=5000

# MySQL（与 Windows 组员保持一致，按本机实际修改）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=movies_db
